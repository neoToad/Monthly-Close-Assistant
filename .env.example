# Monthly Close Assistant — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# QuickBooks OAuth variables are added in Prompt 3 and hardened in Prompt 4.

# ---- Django ----
# Used by close_assistant/settings.py via python-decouple.
# Generate a real key for any non-local deployment.
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- PostgreSQL ----
# The Django app connects with these. For the local Docker dev DB:
#   docker run -d --name close_pg -e POSTGRES_DB=close_assistant \
#     -e POSTGRES_USER=close_app -e POSTGRES_PASSWORD=<DB_PASSWORD> \
#     -p 5434:5432 postgres:17
# (Host port 5434: this machine's local PG 17 & 18 already bind 5432 and 5433.)
DB_NAME=close_assistant
DB_USER=close_app
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5434

# ---- QuickBooks Online OAuth (Prompts 3 & 4) ----
# Register an app at https://developer.intuit.com and fill these in from the app's
# "Keys & OAuth" tab.
# QB_CLIENT_ID: the OAuth 2.0 Client ID for your Intuit app.
QB_CLIENT_ID=
# QB_CLIENT_SECRET: the OAuth 2.0 Client Secret for your Intuit app.
QB_CLIENT_SECRET=
# QB_REDIRECT_URI: must exactly match a redirect URI registered in the Intuit
# dashboard. Use http://localhost:8000/quickbooks/oauth/callback/ for local dev.
QB_REDIRECT_URI=http://localhost:8000/quickbooks/oauth/callback/
# QB_SANDBOX_COMPANY_ID: the realm id of the sandbox company you are syncing.
QB_SANDBOX_COMPANY_ID=
# QB_ENVIRONMENT: which QuickBooks API environment to target.
#   - sandbox    -> https://sandbox-quickbooks.api.intuit.com/v3/company/
#   - production -> https://quickbooks.api.intuit.com/v3/company/
# Use "sandbox" for local development and the QuickBooks Sandbox API.
QB_ENVIRONMENT=sandbox

# ---- Token encryption (Prompt 3) ----
# Fernet key used to encrypt QuickBooks access/refresh tokens at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for local dev (tokens stored in plaintext; a warning is emitted).
QB_TOKEN_ENCRYPTION_KEY=

# ---- Token refresh buffer (Prompt 4) ----
# How many minutes before access-token expiry to treat the token as expired and
# refresh it proactively. Default is 15 minutes; increase if your sync runs long.
QB_TOKEN_REFRESH_BUFFER_MINUTES=15

# ---- Close-summary agent (Prompt 10) ----
# Anthropic API key used by the LangGraph/LangChain close-summary agent.
# Get one at https://console.anthropic.com/. If left blank, the agent falls back
# to a deterministic, rule-generated summary for local development and tests.
ANTHROPIC_API_KEY=
# Optional: override the Claude model used for summaries (defaults to claude-sonnet-4-6).
CLOSE_SUMMARY_MODEL=claude-sonnet-4-6
