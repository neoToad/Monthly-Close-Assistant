# ---- Secrets / environment ----
# Keep credentials (QuickBooks OAuth, LLM API keys, DB passwords) out of git.
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

